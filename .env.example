# Supabase — public (safe to expose to the browser / Next.js client)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Canonical site URL — used as the redirect target for auth emails (invites,
# password resets). Falls back to the request origin if unset, but set this
# explicitly on Vercel so emails sent from cron / background jobs still work.
NEXT_PUBLIC_SITE_URL=

# Supabase — server-only (NEVER expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=
